{
  "compilerOptions": {
    "target": "es2016",
    "module": "es6",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "moduleResolution": "node",
    "baseUrl": ".",
    "noEmit": true,
    "isolatedModules": true,
    "paths": {
      "@/*": ["src/*"],
      "@js/*": ["src/js/*"],
      "@style/*": ["src/style/*"]
    }
  }
}
